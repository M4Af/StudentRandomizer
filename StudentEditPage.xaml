<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp3.Views.StudentEditPage"
             Title="StudentEditPage">
    <Grid RowDefinitions="Auto,*,Auto" BackgroundColor="#F5DEB3">
        <VerticalStackLayout Grid.Row="0" Padding="20" Spacing="15" BackgroundColor="#FF6B35">
            <Label x:Name="ClassNameLabel" Text="> KLASA" StyleClass="header-label"/>
            <VerticalStackLayout Spacing="10">
                <Label Text="[DODAJ UCZNIA]:" TextColor="#FFFFFF" FontAttributes="Bold" FontSize="12"/>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Entry x:Name="NewStudentNameEntry" Placeholder="Imię i nazwisko" StyleClass="entry-style"/>
                    <Button Text="[ADD]" Clicked="OnAddStudentClicked" StyleClass="primary-button" Grid.Column="1"/>
                </Grid>
            </VerticalStackLayout>
            <Button Text="[NOWY SZCZĘŚLIWY NUMEREK]" Clicked="OnGenerateNewLuckyNumberClicked" StyleClass="warning"/>
        </VerticalStackLayout>

        <CollectionView x:Name="StudentsCollectionView" Grid.Row="1" BackgroundColor="#F5DEB3">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame StyleClass="primary-frame">
                        <VerticalStackLayout Spacing="5">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsPresent}"/>
                                <Label Grid.Column="1" Text="{Binding Name}" StyleClass="section-heading" VerticalOptions="Center"/>
                                <Button Grid.Column="2" Text="[E]" Clicked="OnEditStudentClicked" StyleClass="small-button" CommandParameter="{Binding Id}"/>
                                <Button Grid.Column="3" Text="[X]" Clicked="OnDeleteStudentClicked" StyleClass="small-button danger" CommandParameter="{Binding Id}"/>
                            </Grid>
                            <Label Text="{Binding LuckyCount, StringFormat='> Szczęśliwe: {0}'}" TextColor="#FF6B35" FontAttributes="Bold" FontSize="11"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" Text="[SAVE DATA]" Clicked="OnSaveClicked" Padding="20" Margin="10" StyleClass="primary-button"/>
    </Grid>
</ContentPage>