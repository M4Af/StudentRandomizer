<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp3.Views.StudentDrawPage"
             Title="StudentDrawPage">
    <Grid RowDefinitions="Auto,*,Auto" BackgroundColor="#F5DEB3">
        <VerticalStackLayout Grid.Row="0" Padding="20" Spacing="10" BackgroundColor="#DC143C">
            <Label Text=">>> LOSOWANIE UCZNIA " StyleClass="header-label" HorizontalTextAlignment="Center"/>
            <Label x:Name="LuckyNumberLabel" Text="[SZCZĘŚLIWY NUMEREK: ---]" TextColor="#FFFFFF" FontAttributes="Bold" FontSize="12" HorizontalTextAlignment="Center"/>
            <Picker x:Name="ClassPicker" Title="[WYBIERZ KLASĘ]" TitleColor="#FFFFFF" TextColor="#FFFFFF" BackgroundColor="#FF1744" SelectedIndexChanged="OnClassSelected"/>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Padding="20" Spacing="20" BackgroundColor="#F5DEB3">
            <Frame StyleClass="result-frame">
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="[WYLOSOWANA OSOBA]" TextColor="#DC143C" FontAttributes="Bold" FontSize="12" HorizontalTextAlignment="Center"/>
                    <Label x:Name="DrawnNameLabel" Text="---" StyleClass="drawn-name"/>
                    <Label x:Name="IsLuckyLabel" Text="*** SZCZĘŚLIWY NUMEREK ***" StyleClass="lucky-message" IsVisible="False"/>
                </VerticalStackLayout>
            </Frame>

            <Label Text="[HISTORIA LOSOWAŃ]:" StyleClass="section-heading"/>
            <CollectionView x:Name="HistoryCollectionView" BackgroundColor="#F5DEB3">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="5"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Padding="10" Spacing="3" BackgroundColor="#FFFACD">
                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="12" TextColor="#1A1A1A"/>
                            <Label Text="{Binding TimesAsked, StringFormat='> Pytań: {0}'}" FontSize="11" TextColor="#8B4513"/>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="2" Padding="20" Spacing="10" BackgroundColor="#F5DEB3">
            <Button x:Name="DrawBtn" Text="*** LOSUJ! ***" Clicked="OnDrawClicked" StyleClass="draw-button" IsEnabled="False"/>
            <Button Text="[RESET SESJI]" Clicked="OnResetClicked" StyleClass="secondary-button"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>