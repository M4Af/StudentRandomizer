<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp3.Views.MainPage"
             Title="MainPage">
    <VerticalStackLayout Padding="20" Spacing="20" BackgroundColor="#F5DEB3" VerticalOptions="Center">

        <Label Text="STUDENT RANDOMIZER" StyleClass="main-title"/>
        <Label Text="=== SYSTEM LOSOWANIA ===" StyleClass="subtitle"/>

        <Frame StyleClass="info-frame">
            <VerticalStackLayout Spacing="10">
                <Label Text="> DOSTEPNE FUNKCJE:" StyleClass="section-heading"/>
                <Label Text="Zarządzaj klasami i uczniami" StyleClass="normal-label"/>
                <Label Text="Losuj uczniów do odpowiedzi" StyleClass="normal-label"/>
                <Label Text="System szczęśliwego numerka" StyleClass="normal-label"/>
                <Label Text="Sprawdzanie obecności" StyleClass="normal-label"/>
            </VerticalStackLayout>
        </Frame>

        <Button Text=">>> ZARZĄDZAJ KLASAMI " Clicked="OnGoToClassesClicked" StyleClass="primary-button"/>
        <Button Text=">>> LOSUJ UCZNIA " Clicked="OnGoToDrawClicked" StyleClass="primary-button"/>
    </VerticalStackLayout>
</ContentPage>